# Copy to .env — never commit .env to git.

# Database
DATABASE_URL=postgresql://level:level_dev@localhost:5432/level_dev

# Redis
REDIS_URL=redis://localhost:6379

# Clerk Auth
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Sentry (API)
SENTRY_DSN=https://...@sentry.io/...

# Sentry (web app)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=levelup-web

# Grafana Cloud (Loki logging) — optional in development
GRAFANA_LOKI_URL=https://logs-prod-us-central1.grafana.net
GRAFANA_LOKI_USER=123456
GRAFANA_LOKI_PASSWORD=your-grafana-api-token

# Environment
NODE_ENV=development
